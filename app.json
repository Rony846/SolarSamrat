{
  "expo": {
    "name": "Solar Samrat",
    "slug": "solar-samrat",
    "version": "1.0.0",
    "scheme": "solarsamrat",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#110E07"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.solarsamrat.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "in.solarsamrat.app",
      "adaptiveIcon": {
        "backgroundColor": "#110E07",
        "foregroundImage": "./assets/adaptive-icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Solar Samrat to attach photos to your posts and business profile."
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#F4B740"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "owner": "rony846"
  }
}
